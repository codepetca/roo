		"@types/node": "^22.0.0",
		"autoprefixer": "^10.4.0",
		"eslint": "^9.0.0",
		"jsdom": "^26.1.0",
		"postcss": "^8.4.0",
		"prettier": "^3.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
